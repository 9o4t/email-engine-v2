# ============================================================================
# email-engine-v2 — env config
# ============================================================================

# --- Mailboxes (first-boot seed) ---------------------------------------------
# The poller seeds the SQLite mailbox_config table from these env vars on
# FIRST boot only. After that, the UI at /mailboxes is the source of truth —
# changes there don't get overwritten by env on next boot.

# Microsoft Graph mailboxes (use the token broker). Comma-separated emails.
MAILBOXES_GRAPH=dave@9o4t.com

# IMAP (Gmail / Workspace) mailboxes. Each row: email|server|port (server+port optional, default imap.gmail.com:993).
# Per-mailbox app password lives in IMAP_<SANITIZED_EMAIL>_PASSWORD (see below).
# MAILBOXES_IMAP=dave@example.com|imap.gmail.com|993

DEFAULT_APPLY_MODE=tag_and_move    # tag | move | tag_and_move
POLL_INTERVAL_SEC=30

# --- Microsoft Graph token broker --------------------------------------------
# Same broker the existing email-engine uses. The Python TokenBroker POSTs
# `[{"token_check":"start"}]` to CALENDAR_URL with header `bearer: $B2B_TOKEN`
# and expects `[{"bearer_token":"...","minutes_left":50}]` back.
CALENDAR_URL=https://your-n8n-instance/webhook/...
B2B_TOKEN=...

# --- IMAP per-mailbox app passwords ------------------------------------------
# Naming rule: IMAP_<SANITIZED_EMAIL>_PASSWORD where sanitization is
# lowercase + non-alnum→'_'.  e.g. dave@gmail.com → IMAP_DAVE_GMAIL_COM_PASSWORD
# (NOT a database column — Railway secrets are the right home for this.)
# IMAP_DAVE_GMAIL_COM_PASSWORD=...

# --- LLM (OpenAI-compatible endpoint) ----------------------------------------
# Examples:
#   OpenAI:       LLM_BASE_URL=https://api.openai.com/v1            LLM_MODEL=gpt-4o-mini
#   OpenRouter:   LLM_BASE_URL=https://openrouter.ai/api/v1         LLM_MODEL=anthropic/claude-haiku-4-5
#   Ollama:       LLM_BASE_URL=http://ollama:11434/v1               LLM_MODEL=qwen2.5:7b
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-REPLACE_ME

# --- Web UI ------------------------------------------------------------------
# Refuses (503) when either is empty. Use long random values in production.
WEB_USER=admin
WEB_PASS=REPLACE_WITH_A_LONG_RANDOM_STRING

# --- Storage -----------------------------------------------------------------
# Mount a Railway Volume at /data so the DB survives redeploys.
FEEDBACK_DB_PATH=/data/email-engine-v2.db

# --- Misc -------------------------------------------------------------------
LOG_LEVEL=INFO
PORT=8000
